# 编辑器配置文件，用于统一代码编辑器的格式化设置，确保团队成员使用不同编辑器时代码风格保持一致。

root = true  # 表示这是项目根目录的配置

[*]  # 适用于所有文件
charset = utf-8           # 字符编码
indent_style = space      # 缩进使用空格
indent_size = 2           # 缩进宽度2个空格
insert_final_newline = true     # 文件末尾插入空行
trim_trailing_whitespace = true  # 去除行尾空格
end_of_line = lf          # 换行符使用LF（Unix风格）

[*.md]  # 仅适用于Markdown文件
trim_trailing_whitespace = false  # Markdown保留行尾空格